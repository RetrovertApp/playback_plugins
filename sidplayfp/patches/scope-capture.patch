+unsigned int ReSIDfpBuilder::getScopeData(int channel, float* buffer, unsigned int numSamples)
+{
+    // Map channel to SID instance and voice
+    // Channels 0-2 = SID 0, 3-5 = SID 1, 6-8 = SID 2
+    int sidIdx = channel / 3;
+    int voiceIdx = channel % 3;
+
+    int i = 0;
+    for (libsidplayfp::sidemu* e : sidobjs)
+    {
+        if (i == sidIdx)
+        {
+            auto* emu = static_cast<libsidplayfp::ReSIDfp*>(e);
+            const short* voiceBuf = emu->getVoiceBuffer(voiceIdx);
+            int writePos = emu->getVoiceBufferPos();
+            int bufSize = emu->getVoiceBufferSize();
+
+            if (voiceBuf == nullptr || bufSize <= 0)
+                return 0;
+
+            if (numSamples > static_cast<unsigned int>(bufSize))
+                numSamples = static_cast<unsigned int>(bufSize);
+
+            // Per-channel read position tracking.
+            // Instead of always reading the most recent N samples (which causes
+            // phase jumps when the read rate doesn't match the write rate),
+            // we maintain a sliding output buffer that appends only NEW samples
+            // since the last call. This provides continuous, phase-coherent data.
+            static float outputBuf[9][4096];     // 3 SIDs * 3 voices max
+            static int lastReadPos[9] = {0};
+            static bool initialized[9] = {false};
+
+            int ch = sidIdx * 3 + voiceIdx;
+            if (ch >= 9) return 0;
+
+            if (!initialized[ch])
+            {
+                // First call: fill with the most recent data
+                lastReadPos[ch] = writePos;
+                const float norm = 1.0f / 65280.0f;
+                int readPos = (writePos - static_cast<int>(numSamples) + bufSize) & (bufSize - 1);
+                for (unsigned int s = 0; s < numSamples; s++)
+                {
+                    float sample = static_cast<float>(voiceBuf[readPos]) * norm;
+                    if (sample > 1.0f) sample = 1.0f;
+                    else if (sample < -1.0f) sample = -1.0f;
+                    outputBuf[ch][s] = sample;
+                    readPos = (readPos + 1) & (bufSize - 1);
+                }
+                initialized[ch] = true;
+            }
+            else
+            {
+                // Calculate how many new samples the writer has produced
+                int newSamples = (writePos - lastReadPos[ch] + bufSize) & (bufSize - 1);
+
+                // Clamp to buffer size (if we fell too far behind, skip ahead)
+                if (newSamples > static_cast<int>(numSamples))
+                    newSamples = static_cast<int>(numSamples);
+
+                if (newSamples > 0)
+                {
+                    // Shift existing data left to make room for new samples
+                    int keep = static_cast<int>(numSamples) - newSamples;
+                    for (int s = 0; s < keep; s++)
+                        outputBuf[ch][s] = outputBuf[ch][s + newSamples];
+
+                    // Append new samples at the end
+                    const float norm = 1.0f / 65280.0f;
+                    int readPos = (writePos - newSamples + bufSize) & (bufSize - 1);
+                    for (int s = 0; s < newSamples; s++)
+                    {
+                        float sample = static_cast<float>(voiceBuf[readPos]) * norm;
+                        if (sample > 1.0f) sample = 1.0f;
+                        else if (sample < -1.0f) sample = -1.0f;
+                        outputBuf[ch][keep + s] = sample;
+                        readPos = (readPos + 1) & (bufSize - 1);
+                    }
+                }
+            }
+
+            lastReadPos[ch] = writePos;
+            memcpy(buffer, outputBuf[ch], numSamples * sizeof(float));
+            return numSamples;
+        }
+        i++;
+    }
+
+    return 0;
+}
